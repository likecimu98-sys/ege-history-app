rules_version = '2';

// Firebase is a rollback archive after the PostgreSQL cutover. Production
// clients, including stale PWA versions, must use the first-party VPS API.
// Admin SDK access used by the temporary mirror/backups is not affected by
// Firestore Security Rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
